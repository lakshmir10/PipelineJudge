# PipelineJudge Configuration
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (local dev — default, no setup needed):
DATABASE_URL=sqlite:///./pipelinejudge.db

# PostgreSQL (production — uncomment and fill in):
# DATABASE_URL=postgresql://pipelinejudge:yourpassword@localhost:5432/pipelinejudge

# ── LLM Judges ────────────────────────────────────────────────────────────
# Default: content-aware mock judges (no API key needed, good for demo)
PIPELINEJUDGE_MOCK_LLM=true

# To use real LLM judges, set mock to false and provide an API key:
# PIPELINEJUDGE_MOCK_LLM=false
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Which model to use for LLM judges (only matters when mock is false):
# PIPELINEJUDGE_LLM_MODEL=claude-sonnet-4-20250514
# PIPELINEJUDGE_LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
